    { "name": "Ινσουλίνη",      "alt_names": ["Insulin", "Ins"],                  "unit": "mIU/L",   "range": "2-12",     "plausible_min": 0.5, "plausible_max": 300,  "notes": "Fasting. >12 suggests insulin resistance. >20 significant" },
    { "name": "HOMA-IR",        "alt_names": [],                                   "unit": "score",   "range": "<1,0",     "plausible_min": 0,   "plausible_max": 30,   "notes": "Calculated: (insulin × glucose) / 405. >3,0 = significant IR" },
